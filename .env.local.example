# API key（官方或代理服务颁发的都填这里）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 自定义 API 地址（可选）
# - 不填 / 留空 → 走官方 https://api.anthropic.com/v1
# - 走代理或第三方转发 → 填到 /v1 那一级，例如：
#   ANTHROPIC_BASE_URL=https://your-proxy.example.com/v1
ANTHROPIC_BASE_URL=

# Tavily 联网搜索（可选，不填则 web_search 工具会返回提示）
# 免费额度：https://tavily.com/
TAVILY_API_KEY=
